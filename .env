# ── Active app & environment ──────────────────────────────────────────────────
# APP controls WHICH application to test  (orangeHRM | contactList)
# ENV controls WHICH environment to run   (dev | staging | prod)

APP=orangeHRM
ENV=staging

# ── OrangeHRM URLs ────────────────────────────────────────────────────────────
ORANGEHRM_DEV_URL=https://dev-orangehrm.yourdomain.com
ORANGEHRM_STAGING_URL=https://opensource-demo.orangehrmlive.com
ORANGEHRM_PROD_URL=https://prod-orangehrm.yourdomain.com

# ── ContactList URLs ──────────────────────────────────────────────────────────
CONTACTLIST_DEV_URL=https://dev-contactlist.yourdomain.com
CONTACTLIST_STAGING_URL=https://thinking-tester-contact-list.herokuapp.com
CONTACTLIST_PROD_URL=https://prod-contactlist.yourdomain.com